# Copiá a `.env` (gitignored) y completá con valores reales y fuertes.
# docker compose lee este archivo automáticamente.

# Base de datos
POSTGRES_DB=custos_db
POSTGRES_PASSWORD=cambiar_por_password_fuerte_admin
APP_DB_PASSWORD=cambiar_por_password_fuerte_app

# URL de la base de datos para la app (con RLS aplicado)
DATABASE_URL=postgresql://custos_app:APP_DB_PASSWORD@postgres:5432/custos_db?schema=public

# URL de la base de datos para migraciones (sin RLS, usuario admin)
MIGRATE_DATABASE_URL=postgresql://postgres:POSTGRES_PASSWORD@postgres:5432/custos_db?schema=public

# Autenticación (generá uno: openssl rand -hex 32)
JWT_SECRET=cambiar_por_secreto_largo_aleatorio

# Puerto del servidor API (default: 3000)
PORT=3000

# URL del frontend permitida por CORS
FRONTEND_URL=http://localhost:5173

# Redis (para BullMQ / notificaciones)
# Opción 1: URL completa (tiene precedencia sobre HOST/PORT)
REDIS_URL=redis://redis:6379
# Opción 2: host y puerto separados
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO (almacenamiento de archivos S3-compatible)
MINIO_USER=custos_minio
MINIO_PASSWORD=cambiar_por_password_minio
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=custos-archivos
