  tenant_id     String    @db.Uuid
  objetivo_id   String    @db.Uuid
  tipo          String // PANEL_ALARMA | ENERGIZADOR_CERCO | DVR | NVR | CAMARA_IP | COMUNICADOR | BOTON_PANICO
  protocolo     String // SIA_DC09 | CONTACT_ID | ONVIF | ISAPI | DAHUA | MQTT | MODBUS | SNMP | HTTP
  marca         String?
  modelo        String?
  nro_abonado   String? // cuenta del panel
  params        Json      @default("{}") // ip, puerto, usuario, secreto_ref, aes_key_ref, supervision_seg
  estado        String    @default("FUERA_DE_LINEA") // EN_LINEA | FUERA_DE_LINEA | EN_FALLA | DESHABILITADO
