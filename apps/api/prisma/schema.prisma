// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre            String // Nombre Comercial
  razon_social      String?
  cuit              String? @unique
  condicion_iva     String? // RESPONSABLE_INSCRIPTO | MONOTRIBUTO | EXENTO | CONSUMIDOR_FINAL
  direccion         String?
  logo_url          String?
  email_contacto    String?
  telefono_contacto String?

  factor_cobertura Decimal  @default(4.20) @db.Decimal(4, 2)
  margen_objetivo  Decimal  @default(0.2500) @db.Decimal(5, 4)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @db.Timestamptz

  users                   User[]
  vigiladores             Vigilador[]
  credenciales            Credencial[]
  objetivos               Objetivo[]
  puestos                 Puesto[]
  asignaciones            Asignacion[]
  asistencias             Asistencia[]
  feriados                Feriado[]
  configuracion_costos    ConfiguracionCostos?
  cotizaciones            Cotizacion[]
  novedades               Novedad[]
  puntos_control          PuntoControl[]
  rondas                  Ronda[]
  umbrales_aprobacion     UmbralAprobacion[]
  solicitudes_compra      SolicitudCompra[]
  ordenes_compra          OrdenCompra[]
  vehiculos               Vehiculo[]
  dispositivos            Dispositivo[]
  eventos                 Evento[]
  incidentes              Incidente[]
  procedimientos          Procedimiento[]
  programaciones_horarias ProgramacionHoraria[]
  contratos               Contrato[]
  periodos                Periodo[]
  contrato_facturaciones  ContratoFacturacion[]
  conciliaciones_hh       ConciliacionHH[]
  auditorias              Auditoria[]
  notificaciones          Notificacion[]
  esquemas_turno          EsquemaTurno[]
  asignaciones_esquema    AsignacionEsquema[]
  turnos_planificados     TurnoPlanificado[]
  puesto_coberturas       PuestoCobertura[]
  reglas_laborales        ReglaLaboral?
  relevos                 Relevo[]
  herramientas            Herramienta[]
  herramienta_asignaciones HerramientaAsignacion[]
  catalogo_items          CatalogoItem[]
  clientes                Cliente[]

  @@map("tenants")
}

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  email           String    @unique
  password        String
  role            String    @default("OPERADOR") // ADMIN | GERENCIA | SUPERVISOR | OPERADOR | RRHH | COMPRAS
  failed_attempts Int       @default(0)
  locked_until    DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @default(now()) @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  tenant      Tenant            @relation(fields: [tenant_id], references: [id])
  solicitudes SolicitudCompra[]

  @@map("users")
}

model Vigilador {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String    @db.Uuid
  legajo_nro String
  nombre     String
  apellido   String
  documento  String
  estado     String    @default("ACTIVO")
  // Wizard de alta guiada (PROMPT_UX_ONBOARDING_GUIADO.md §4)
  foto_url                String?
  domicilio               String?
  localidad               String?
  provincia               String?
  codigo_postal           String?
  telefono                String?
  contacto_emerg_nombre   String?
  contacto_emerg_telefono String?
  contacto_emerg_vinculo  String?
  completitud             String    @default("INCOMPLETO") // INCOMPLETO | COMPLETO
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @default(now()) @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  tenant       Tenant       @relation(fields: [tenant_id], references: [id])
  credenciales Credencial[]
  asignaciones Asignacion[]
  novedades    Novedad[]
  rondas       Ronda[]
  herramientas HerramientaAsignacion[]

  @@unique([tenant_id, legajo_nro])
  @@map("vigiladores")
}

model Credencial {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  vigilador_id String    @db.Uuid
  tipo         String // CARNET_VIGILADOR | PSICOFISICO | ANTECEDENTES | ANMAC | CAPACITACION
  numero       String?
  organismo    String?
  emitida_el   DateTime? @db.Date
  vence_el     DateTime? @db.Date
  documento_url String?
  documento_key String?
  created_at   DateTime  @default(now()) @db.Timestamptz

  tenant    Tenant    @relation(fields: [tenant_id], references: [id])
  vigilador Vigilador @relation(fields: [vigilador_id], references: [id])

  @@map("credenciales")
}

// Listas configurables por tenant (ej: tipos de credencial, tipos de vehículo).
// `categoria` agrupa los items de una misma lista; el tenant puede agregar
// los suyos además de los valores por defecto que ya entiende el resto del sistema.
model CatalogoItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  categoria  String
  codigo     String
  etiqueta   String
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, categoria, codigo])
  @@map("catalogo_items")
}

// Cliente/Empresa: entidad real que consolida lo que antes era un
// cliente_nombre de texto libre duplicado en Cotizacion/Contrato/Objetivo.
// cliente_id es opcional para no romper la carga rápida de cotizaciones;
// cuando está presente, cliente_nombre se completa como snapshot del
// razon_social al momento de la operación (no se recalcula después).
model Cliente {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String    @db.Uuid
  razon_social      String
  nombre_fantasia   String?
  cuit              String?
  domicilio         String?
  localidad         String?
  provincia         String?
  contacto_nombre   String?
  contacto_email    String?
  contacto_telefono String?
  estado            String    @default("ACTIVO") // ACTIVO | INACTIVO
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @default(now()) @db.Timestamptz
  deleted_at        DateTime? @db.Timestamptz

  tenant     Tenant       @relation(fields: [tenant_id], references: [id])
  objetivos  Objetivo[]
  cotizaciones Cotizacion[]
  contratos  Contrato[]

  @@map("clientes")
}

model Objetivo {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  cliente_id     String?  @db.Uuid
  // cliente_nombre sigue la misma convención que Cotizacion/Contrato.
  // Es un snapshot: si hay cliente_id, se completa desde Cliente.razon_social.
  cliente_nombre String
  codigo         String
  nombre         String
  direccion      String?
  estado         String   @default("ACTIVO") // ACTIVO | INACTIVO
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @db.Timestamptz
  lat            Float?
  lng            Float?

  tenant         Tenant                @relation(fields: [tenant_id], references: [id])
  cliente        Cliente?              @relation(fields: [cliente_id], references: [id])
  puestos        Puesto[]
  dispositivos   Dispositivo[]
  eventos        Evento[]
  incidentes     Incidente[]
  contactos      ContactoEmergencia[]
  programaciones ProgramacionHoraria[]
  contratos      Contrato[]

  @@unique([tenant_id, codigo])
  @@map("objetivos")
}

model Puesto {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @db.Uuid
  objetivo_id     String?  @db.Uuid
  nombre          String
  ubicacion       String?
  lat             Float?
  lng             Float?
  requiere_arma   Boolean  @default(false)
  requiere_movil  Boolean  @default(false)
  esquema_horario Json?
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @db.Timestamptz

  tenant         Tenant         @relation(fields: [tenant_id], references: [id])
  objetivo       Objetivo?      @relation(fields: [objetivo_id], references: [id])
  asignaciones   Asignacion[]
  novedades      Novedad[]
  puntos_control PuntoControl[]
  rondas         Ronda[]

  @@unique([tenant_id, objetivo_id, nombre])
  @@map("puestos")
}

model Asignacion {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String   @db.Uuid
  puesto_id    String   @db.Uuid
  vigilador_id String?  @db.Uuid
  fecha        DateTime @db.Date
  hora_inicio  String
  hora_fin     String
  estado       String   @default("PLANIFICADA")
  created_at   DateTime @default(now()) @db.Timestamptz

  tenant     Tenant      @relation(fields: [tenant_id], references: [id])
  puesto     Puesto      @relation(fields: [puesto_id], references: [id])
  vigilador  Vigilador?  @relation(fields: [vigilador_id], references: [id])
  asistencia Asistencia?

  @@unique([puesto_id, fecha, hora_inicio], name: "puesto_id_fecha_hora_inicio")
  @@map("asignaciones")
}

model Asistencia {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  asignacion_id String    @unique @db.Uuid
  inicio_real   DateTime? @db.Timestamptz
  fin_real      DateTime? @db.Timestamptz
  metodo        String? // GEO | QR | NFC | MANUAL
  lat           Decimal?  @db.Decimal(9, 6)
  lng           Decimal?  @db.Decimal(9, 6)

  tenant     Tenant     @relation(fields: [tenant_id], references: [id])
  asignacion Asignacion @relation(fields: [asignacion_id], references: [id])

  @@map("asistencias")
}

model Feriado {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  nombre     String
  fecha      DateTime @db.Date
  created_at DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("feriados")
}

model ConfiguracionCostos {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @unique @db.Uuid
  costo_hora_base Decimal  @db.Decimal(12, 2)
  cargas_sociales Decimal  @db.Decimal(5, 4) // e.g. 0.45
  costos_uniforme Decimal  @db.Decimal(12, 2)
  otros_costos    Decimal  @db.Decimal(12, 2)
  factor_ajuste   Decimal  @default(1.0) @db.Decimal(5, 4)
  updated_at      DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("configuracion_costos")
}

model Cotizacion {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  cliente_id     String?  @db.Uuid
  cliente_nombre String
  vencimiento    DateTime @db.Date
  estado         String   @default("BORRADOR") // BORRADOR | ENVIADA | ACEPTADA | RECHAZADA
  total_mensual  Decimal  @db.Decimal(14, 2)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @db.Timestamptz

  tenant    Tenant           @relation(fields: [tenant_id], references: [id])
  cliente   Cliente?         @relation(fields: [cliente_id], references: [id])
  items     CotizacionItem[]
  contratos Contrato[]

  @@map("cotizaciones")
}

model CotizacionItem {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cotizacion_id   String  @db.Uuid
  puesto_nombre   String
  horas_mensuales Int
  costo_hora      Decimal @db.Decimal(12, 2)
  margen          Decimal @db.Decimal(5, 4)
  subtotal        Decimal @db.Decimal(14, 2)

  cotizacion Cotizacion @relation(fields: [cotizacion_id], references: [id])

  @@map("cotizacion_items")
}

model Novedad {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String   @db.Uuid
  puesto_id    String?  @db.Uuid
  vigilador_id String?  @db.Uuid
  tipo         String // GENERAL | ALARMA | RELEVAMIENTO | EMERGENCIA
  prioridad    String   @default("NORMAL") // BAJA | NORMAL | ALTA | CRITICA
  descripcion  String
  adjuntos     String[] // URLs in MinIO
  created_at   DateTime @default(now()) @db.Timestamptz

  tenant    Tenant     @relation(fields: [tenant_id], references: [id])
  puesto    Puesto?    @relation(fields: [puesto_id], references: [id])
  vigilador Vigilador? @relation(fields: [vigilador_id], references: [id])

  @@map("novedades")
}

model PuntoControl {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  puesto_id  String   @db.Uuid
  nombre     String
  codigo_qr  String?  @unique
  nfc_id     String?  @unique
  lat        Float?
  lng        Float?
  created_at DateTime @default(now()) @db.Timestamptz

  tenant Tenant       @relation(fields: [tenant_id], references: [id])
  puesto Puesto       @relation(fields: [puesto_id], references: [id])
  marcas MarcaRonda[]

  @@map("puntos_control")
}

model Ronda {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  puesto_id    String    @db.Uuid
  vigilador_id String    @db.Uuid
  nombre       String
  hora_inicio  DateTime  @default(now()) @db.Timestamptz
  hora_fin     DateTime? @db.Timestamptz
  estado       String    @default("EN_PROGRESO") // EN_PROGRESO | COMPLETADA | INCOMPLETA

  tenant    Tenant       @relation(fields: [tenant_id], references: [id])
  puesto    Puesto       @relation(fields: [puesto_id], references: [id])
  vigilador Vigilador    @relation(fields: [vigilador_id], references: [id])
  marcas    MarcaRonda[]

  @@map("rondas")
}

model MarcaRonda {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ronda_id         String   @db.Uuid
  punto_control_id String   @db.Uuid
  timestamp        DateTime @default(now()) @db.Timestamptz
  lat              Float?
  lng              Float?

  ronda         Ronda        @relation(fields: [ronda_id], references: [id])
  punto_control PuntoControl @relation(fields: [punto_control_id], references: [id])

  @@map("marcas_ronda")
}

model UmbralAprobacion {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String   @db.Uuid
  monto_max_supervisor Decimal  @db.Decimal(14, 2)
  created_at           DateTime @default(now()) @db.Timestamptz
  updated_at           DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("umbrales_aprobacion")
}

model SolicitudCompra {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  user_id        String   @db.Uuid
  descripcion    String
  monto_estimado Decimal  @db.Decimal(14, 2)
  estado         String   @default("PENDIENTE") // PENDIENTE | APROBADA | RECHAZADA
  contrato_id    String?  @db.Uuid
  vehiculo_id    String?  @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz

  tenant  Tenant        @relation(fields: [tenant_id], references: [id])
  user    User          @relation(fields: [user_id], references: [id])
  ordenes OrdenCompra[]

  @@map("solicitudes_compra")
}

model OrdenCompra {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  solicitud_id     String?  @db.Uuid
  proveedor_nombre String
  total            Decimal  @db.Decimal(14, 2)
  total_pagado     Decimal  @default(0) @db.Decimal(14, 2)
  estado           String   @default("EN_APROBACION") // EN_APROBACION | APROBADA | RECIBIDA | RECIBIDA_PARCIAL | PAGADA | RECHAZADA
  created_at       DateTime @default(now()) @db.Timestamptz

  tenant    Tenant            @relation(fields: [tenant_id], references: [id])
  solicitud SolicitudCompra?  @relation(fields: [solicitud_id], references: [id])
  items     OrdenCompraItem[]

  @@map("ordenes_compra")
}

model OrdenCompraItem {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orden_id          String  @db.Uuid
  descripcion       String
  cantidad          Decimal @db.Decimal(10, 2)
  cantidad_recibida Decimal @default(0) @db.Decimal(10, 2)
  precio_unitario   Decimal @db.Decimal(14, 2)
  subtotal          Decimal @db.Decimal(14, 2)
  contrato_id       String? @db.Uuid
  vehiculo_id       String? @db.Uuid

  orden OrdenCompra @relation(fields: [orden_id], references: [id])

  @@map("orden_compra_items")
}

model Vehiculo {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  patente    String   @unique
  marca      String?
  modelo     String?
  year       Int?
  // Campos M6 (spec MODELOS L488). codigo/tipo nullable por migración aditiva.
  codigo     String?
  tipo       String? // COMUN | BLINDADO | MOTO
  km_actual  Int      @default(0)
  estado     String   @default("OPERATIVO") // OPERATIVO | EN_TALLER | BAJA
  costo_hora Decimal? @db.Decimal(10, 2)
  created_at DateTime @default(now()) @db.Timestamptz

  tenant       Tenant                @relation(fields: [tenant_id], references: [id])
  vencimientos VehiculoVencimiento[]
  planes       PlanMantenimiento[]
  ordenes      OrdenTrabajo[]
  combustible  CargaCombustible[]
  asignaciones AsignacionMovil[]

  @@unique([tenant_id, codigo])
  @@map("vehiculos")
}

// ─── M6: Flota (mantenimiento, vencimientos, combustible, TCO) ───────────────
// DDL del spec MODELOS_M2_A_M6 L501-561.
model VehiculoVencimiento {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  vehiculo_id String   @db.Uuid
  tipo        String // VTV | SEGURO | PATENTE | HABILITACION_CAUDALES
  vence_el    DateTime @db.Date
  estado      String   @default("VIGENTE") // VIGENTE | POR_VENCER | VENCIDO
  documento_url String?
  created_at  DateTime @default(now()) @db.Timestamptz

  vehiculo Vehiculo @relation(fields: [vehiculo_id], references: [id])

  @@map("vehiculo_vencimientos")
}

// ─── Herramientas/Equipos (PROMPT_UX_ONBOARDING_GUIADO.md §7) ────────────────
model Herramienta {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  codigo       String // HER-2026-0042
  tipo         String // RADIO | HANDIE | CHALECO | ARMA | LINTERNA | OTRO
  descripcion  String
  numero_serie String?
  estado       String    @default("DISPONIBLE") // DISPONIBLE | ASIGNADA | EN_REPARACION | BAJA
  foto_url     String?
  created_at   DateTime  @default(now()) @db.Timestamptz
  deleted_at   DateTime? @db.Timestamptz

  tenant       Tenant                  @relation(fields: [tenant_id], references: [id])
  asignaciones HerramientaAsignacion[]

  @@unique([tenant_id, codigo])
  @@map("herramientas")
}

model HerramientaAsignacion {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String    @db.Uuid
  herramienta_id String    @db.Uuid
  vigilador_id   String    @db.Uuid
  entregada_el   DateTime  @default(now()) @db.Timestamptz
  devuelta_el    DateTime?
  observaciones  String?

  tenant      Tenant      @relation(fields: [tenant_id], references: [id])
  herramienta Herramienta @relation(fields: [herramienta_id], references: [id])
  vigilador   Vigilador   @relation(fields: [vigilador_id], references: [id])

  @@map("herramienta_asignaciones")
}

model PlanMantenimiento {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  vehiculo_id  String    @db.Uuid
  tipo         String // SERVICE | NEUMATICOS | FRENOS ...
  disparo      String // KM | TIEMPO
  cada_km      Int?
  cada_meses   Int?
  ultimo_km    Int?
  ultima_fecha DateTime? @db.Date
  created_at   DateTime  @default(now()) @db.Timestamptz

  vehiculo Vehiculo @relation(fields: [vehiculo_id], references: [id])

  @@map("planes_mantenimiento")
}

model OrdenTrabajo {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  vehiculo_id String   @db.Uuid
  codigo      String // OT-2026-0077
  tipo        String // PREVENTIVA | CORRECTIVA
  estado      String   @default("ABIERTA") // ABIERTA | EN_PROCESO | CERRADA | CANCELADA
  km_al_abrir Int?
  taller      String?
  costo_total Decimal  @default(0) @db.Decimal(14, 2)
  created_at  DateTime @default(now()) @db.Timestamptz

  vehiculo Vehiculo @relation(fields: [vehiculo_id], references: [id])
  items    OtItem[]

  @@unique([tenant_id, codigo])
  @@map("ordenes_trabajo")
}

model OtItem {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  orden_trabajo_id String   @db.Uuid
  descripcion      String
  costo            Decimal  @db.Decimal(14, 2)
  oc_linea_id      String?  @db.Uuid // si el repuesto vino de una OC de M5
  created_at       DateTime @default(now()) @db.Timestamptz

  orden OrdenTrabajo @relation(fields: [orden_trabajo_id], references: [id])

  @@map("ot_items")
}

model CargaCombustible {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  vehiculo_id String   @db.Uuid
  fecha       DateTime @db.Date
  litros      Decimal  @db.Decimal(8, 2)
  importe     Decimal  @db.Decimal(14, 2)
  km          Int
  rendimiento Decimal? @db.Decimal(6, 2) // km/l calculado
  contrato_id String?  @db.Uuid
  objetivo_id String?  @db.Uuid
