// ─── Rentabilidad / Contratos (Fase 5) ──────────────────────────────────────
// Los specs no definen DDL para `contratos`, solo lo referencian ("ganar la
// cotización crea el contrato con su contrato_facturacion"). Se modela mínimo,
// con FKs estructurales a entidades existentes. cliente_nombre es coherente con
// Cotizacion (este esquema no tiene tabla Cliente). // TODO: si se agrega Cliente,
// reemplazar cliente_nombre por cliente_id.
model Contrato {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String    @db.Uuid
  codigo         String // CON-2026-0001
  cliente_id     String?   @db.Uuid
  cliente_nombre String
  objetivo_id    String?   @db.Uuid
  cotizacion_id  String?   @db.Uuid
  estado         String    @default("ACTIVO") // ACTIVO | SUSPENDIDO | FINALIZADO
  inicio         DateTime? @db.Date
  fin            DateTime? @db.Date
  created_at     DateTime  @default(now()) @db.Timestamptz
  updated_at     DateTime  @default(now()) @db.Timestamptz
  deleted_at     DateTime? @db.Timestamptz

  tenant         Tenant               @relation(fields: [tenant_id], references: [id])
  cliente        Cliente?             @relation(fields: [cliente_id], references: [id])
  objetivo       Objetivo?            @relation(fields: [objetivo_id], references: [id])
  cotizacion     Cotizacion?          @relation(fields: [cotizacion_id], references: [id])
  facturacion    ContratoFacturacion?
  conciliaciones ConciliacionHH[]

  @@unique([tenant_id, codigo])
  @@map("contratos")
}

// Definición exacta del spec M1 (MODELO_MOTOR_DE_TIEMPO_Y_CUADRANTE.md L170).
model ContratoFacturacion {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  contrato_id    String   @unique @db.Uuid
  modo           String // POR_PLANIFICADO | POR_REAL | ABONO_FIJO
  tarifa_hora    Decimal? @db.Decimal(14, 2)
  abono_mensual  Decimal? @db.Decimal(14, 2)
  redondeo_min   Int      @default(0) // minutos
  penaliza_hueco Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenant_id], references: [id])
  contrato Contrato @relation(fields: [contrato_id], references: [id])

  @@map("contrato_facturacion")
}

// Definición exacta del spec M1 (MODELO_MOTOR_DE_TIEMPO_Y_CUADRANTE.md L161).
model Periodo {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  tipo       String // QUINCENA | MES
  desde      DateTime @db.Date
  hasta      DateTime @db.Date
  estado     String   @default("ABIERTO") // ABIERTO | EN_CIERRE | CERRADO
  created_at DateTime @default(now()) @db.Timestamptz

  tenant         Tenant           @relation(fields: [tenant_id], references: [id])
  conciliaciones ConciliacionHH[]

  @@map("periodos")
}

// Definición exacta del spec M1 (MODELO_MOTOR_DE_TIEMPO_Y_CUADRANTE.md L181).
// Snapshot por período; al CERRADO queda congelada = true.
model ConciliacionHH {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String  @db.Uuid
  periodo_id      String  @db.Uuid
  contrato_id     String  @db.Uuid
  puesto_id       String? @db.Uuid
  vigilador_id    String? @db.Uuid
  hh_planificadas Decimal @default(0) @db.Decimal(10, 2)
  hh_reales       Decimal @default(0) @db.Decimal(10, 2)
  hh_facturables  Decimal @default(0) @db.Decimal(10, 2)
  hh_normales     Decimal @default(0) @db.Decimal(10, 2)
  hh_nocturnas    Decimal @default(0) @db.Decimal(10, 2)
  hh_extra        Decimal @default(0) @db.Decimal(10, 2)
  hh_feriado      Decimal @default(0) @db.Decimal(10, 2)
  congelada       Boolean @default(false)

  tenant   Tenant   @relation(fields: [tenant_id], references: [id])
  periodo  Periodo  @relation(fields: [periodo_id], references: [id])
  contrato Contrato @relation(fields: [contrato_id], references: [id])

  @@map("conciliacion_hh")
}

// ─── Plataforma: Auditoría y Notificaciones ─────────────────────────────────
// auditoria: registro inmutable (append-only, sin soft-delete) de acciones
// sensibles. DDL del spec MODELOS_M2_A_M6 L609.
model Auditoria {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  actor_id    String   @db.Uuid
  entidad     String // 'ordenes_compra', 'cotizaciones', ...
  entidad_id  String   @db.Uuid
  accion      String // CREAR | EDITAR | APROBAR | ANULAR | CERRAR | REABRIR
  antes       Json?
  despues     Json?
  ocurrida_en DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, entidad, entidad_id])
  @@map("auditoria")
}

// notificaciones: DDL del spec MODELOS_M2_A_M6 L626.
model Notificacion {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  destinatario_id String    @db.Uuid
  tipo            String // CREDENCIAL_POR_VENCER | NOVEDAD_CRITICA | OC_APROBAR | VENCIMIENTO_FLOTA | EROSION_MARGEN
  canal           String // IN_APP | EMAIL | WHATSAPP
  payload         Json
  leida           Boolean   @default(false)
  enviada_en      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, destinatario_id, leida])
  @@map("notificaciones")
}

// ─── M1: Motor de tiempo / Cuadrante ─────────────────────────────────────────
// DDL del spec MODELO_MOTOR_DE_TIEMPO_Y_CUADRANTE.md L95-159.
// NOTA: por simplicidad y para no colisionar con la tabla `asistencias` del
// flujo placeholder (Asignacion), la asistencia real se guarda INLINE en
// turnos_planificados (inicio_real/fin_real/metodo/asistencia_estado).

model ReglaLaboral {
  id                            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                     String   @unique @db.Uuid
  jornada_max_semanal_h         Int      @default(48)
  tope_semanal_con_extra_h      Int      @default(60)
  descanso_min_entre_jornadas_h Int      @default(12)
  max_dias_consecutivos         Int      @default(6)
  ventana_nocturna_inicio       String   @default("21:00")
  ventana_nocturna_fin          String   @default("06:00")
  factor_cobertura              Decimal  @default(4.20) @db.Decimal(4, 2)
  created_at                    DateTime @default(now()) @db.Timestamptz
  updated_at                    DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("reglas_laborales")
}

model EsquemaTurno {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String    @db.Uuid
  nombre     String
  dias_ciclo Int
  definicion Json // ver §3 del spec
  created_at DateTime  @default(now()) @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  tenant       Tenant              @relation(fields: [tenant_id], references: [id])
  asignaciones AsignacionEsquema[]

  @@map("esquemas_turno")
}

model AsignacionEsquema {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String    @db.Uuid
  puesto_id      String    @db.Uuid
  vigilador_id   String    @db.Uuid
  esquema_id     String    @db.Uuid
  posicion_ciclo Int       @default(0)
  fecha_ancla    DateTime  @db.Date
  vigente_desde  DateTime  @db.Date
  vigente_hasta  DateTime? @db.Date
  created_at     DateTime  @default(now()) @db.Timestamptz

  tenant  Tenant             @relation(fields: [tenant_id], references: [id])
  esquema EsquemaTurno       @relation(fields: [esquema_id], references: [id])
  turnos  TurnoPlanificado[]

  @@map("asignaciones_esquema")
}

model TurnoPlanificado {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String    @db.Uuid
  puesto_id             String    @db.Uuid
  vigilador_id          String    @db.Uuid
  asignacion_esquema_id String?   @db.Uuid
  inicio_plan           DateTime  @db.Timestamptz
  fin_plan              DateTime  @db.Timestamptz
  tipo_bloque           String? // DIURNO | NOCTURNO | MIXTO
  estado                String    @default("PLANIFICADA")
  // Asistencia inline (ver NOTA arriba).
  inicio_real           DateTime? @db.Timestamptz
  fin_real              DateTime? @db.Timestamptz
  metodo                String? // GEO | QR | NFC | MANUAL
  asistencia_estado     String    @default("PENDIENTE") // PENDIENTE | OK | OBSERVADA | AUSENTE

  tenant            Tenant             @relation(fields: [tenant_id], references: [id])
  asignacionEsquema AsignacionEsquema? @relation(fields: [asignacion_esquema_id], references: [id])

  @@index([tenant_id, vigilador_id, inicio_plan])
  @@index([tenant_id, puesto_id, inicio_plan])
  @@map("turnos_planificados")
}

model Relevo {
