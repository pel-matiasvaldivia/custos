// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre           String
  factor_cobertura Decimal  @default(4.20) @db.Decimal(4, 2)
  margen_objetivo  Decimal  @default(0.2500) @db.Decimal(5, 4)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @db.Timestamptz

  users            User[]
  vigiladores      Vigilador[]
  credenciales     Credencial[]
  objetivos        Objetivo[]
  puestos          Puesto[]
  asignaciones     Asignacion[]
  asistencias      Asistencia[]
  feriados             Feriado[]
  configuracion_costos ConfiguracionCostos?
  cotizaciones         Cotizacion[]

  @@map("tenants")
}

model User {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  email      String   @unique
  password   String
  role       String   @default("OPERADOR")
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  tenant     Tenant   @relation(fields: [tenant_id], references: [id])

  @@map("users")
}

model Vigilador {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  legajo_nro       String
  nombre           String
  apellido         String
  documento        String
  estado           String   @default("ACTIVO")
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @db.Timestamptz
  deleted_at       DateTime? @db.Timestamptz

  tenant           Tenant       @relation(fields: [tenant_id], references: [id])
  credenciales     Credencial[]
  asignaciones     Asignacion[]

  @@unique([tenant_id, legajo_nro])
  @@map("vigiladores")
}

model Credencial {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String   @db.Uuid
  vigilador_id  String   @db.Uuid
  tipo          String   // CARNET_VIGILADOR | PSICOFISICO | ANTECEDENTES | ANMAC | CAPACITACION
  numero        String?
  organismo     String?
  emitida_el    DateTime? @db.Date
  vence_el      DateTime? @db.Date
  created_at    DateTime @default(now()) @db.Timestamptz

  tenant        Tenant    @relation(fields: [tenant_id], references: [id])
  vigilador     Vigilador @relation(fields: [vigilador_id], references: [id])

  @@map("credenciales")
}

model Objetivo {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  cliente_id String   @db.Uuid
  codigo     String
  nombre     String
  direccion  String?
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  puestos    Puesto[]

  @@unique([tenant_id, codigo])
  @@map("objetivos")
}

model Puesto {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  objetivo_id      String?  @db.Uuid
  nombre           String
  ubicacion        String?
  requiere_arma    Boolean  @default(false)
  requiere_movil   Boolean  @default(false)
  esquema_horario  Json?
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @db.Timestamptz

  tenant           Tenant   @relation(fields: [tenant_id], references: [id])
  objetivo         Objetivo? @relation(fields: [objetivo_id], references: [id])
  asignaciones     Asignacion[]

  @@map("puestos")
}

model Asignacion {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  puesto_id        String   @db.Uuid
  vigilador_id     String?  @db.Uuid
  fecha            DateTime @db.Date
  hora_inicio      String
  hora_fin         String
  estado           String   @default("PLANIFICADA")
  created_at       DateTime @default(now()) @db.Timestamptz

  tenant           Tenant     @relation(fields: [tenant_id], references: [id])
  puesto           Puesto     @relation(fields: [puesto_id], references: [id])
  vigilador        Vigilador? @relation(fields: [vigilador_id], references: [id])
  asistencia       Asistencia?

  @@unique([puesto_id, fecha, hora_inicio], name: "puesto_id_fecha_hora_inicio")
  @@map("asignaciones")
}

model Asistencia {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  asignacion_id    String   @unique @db.Uuid
  inicio_real      DateTime? @db.Timestamptz
  fin_real         DateTime? @db.Timestamptz
  metodo           String?   // GEO | QR | NFC | MANUAL
  lat              Decimal?  @db.Decimal(9, 6)
  lng              Decimal?  @db.Decimal(9, 6)

  tenant           Tenant     @relation(fields: [tenant_id], references: [id])
  asignacion       Asignacion @relation(fields: [asignacion_id], references: [id])

  @@map("asistencias")
}

model Feriado {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  nombre           String
  fecha            DateTime @db.Date
  created_at       DateTime @default(now()) @db.Timestamptz

  tenant           Tenant   @relation(fields: [tenant_id], references: [id])

  @@map("feriados")
}

model ConfiguracionCostos {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid @unique
  costo_hora_base  Decimal  @db.Decimal(12, 2)
  cargas_sociales  Decimal  @db.Decimal(5, 4) // e.g. 0.45
  costos_uniforme  Decimal  @db.Decimal(12, 2)
  otros_costos     Decimal  @db.Decimal(12, 2)
  factor_ajuste    Decimal  @default(1.0) @db.Decimal(5, 4)
  updated_at       DateTime @default(now()) @db.Timestamptz

  tenant           Tenant   @relation(fields: [tenant_id], references: [id])

  @@map("configuracion_costos")
}

model Cotizacion {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  cliente_nombre   String
  vencimiento      DateTime @db.Date
  estado           String   @default("BORRADOR") // BORRADOR | ENVIADA | ACEPTADA | RECHAZADA
  total_mensual    Decimal  @db.Decimal(14, 2)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @db.Timestamptz

  tenant           Tenant   @relation(fields: [tenant_id], references: [id])
  items            CotizacionItem[]

  @@map("cotizaciones")
}

model CotizacionItem {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cotizacion_id    String   @db.Uuid
  puesto_nombre    String
  horas_mensuales  Int
  costo_hora       Decimal  @db.Decimal(12, 2)
  margen           Decimal  @db.Decimal(5, 4)
  subtotal         Decimal  @db.Decimal(14, 2)

  cotizacion       Cotizacion @relation(fields: [cotizacion_id], references: [id])

  @@map("cotizacion_items")
}
